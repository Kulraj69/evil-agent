# FIND EVIL! - Environment configuration template
# Copy this file to `.env` and fill in your real values.
# `.env` is gitignored and will NEVER be committed.
#
#   cp .env.example .env
#
# The agent uses Azure OpenAI for live LLM reasoning. Without these values the
# tools still run; the agent simply falls back to the deterministic offline
# reasoning stand-in (no live model calls).

# ---------------------------------------------------------------------------
# Azure OpenAI
# ---------------------------------------------------------------------------
# Your Azure OpenAI resource endpoint, e.g. https://my-resource.openai.azure.com/
AZURE_OPENAI_ENDPOINT=

# API key from the Azure portal (Keys and Endpoint blade)
AZURE_OPENAI_API_KEY=

# The *deployment name* you created in Azure OpenAI Studio (NOT the base model
# name). E.g. "gpt-4o" or "gpt-4.1" depending on what you deployed.
AZURE_OPENAI_DEPLOYMENT=

# API version. Use a current GA/preview version for your resource.
AZURE_OPENAI_API_VERSION=2024-10-21

# ---------------------------------------------------------------------------
# Optional cost estimation (USD per 1K tokens) for the token-usage logs.
# Leave as-is or update to match your deployment's pricing.
# ---------------------------------------------------------------------------
LLM_INPUT_COST_PER_1K=0.0025
LLM_OUTPUT_COST_PER_1K=0.01
